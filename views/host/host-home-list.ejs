<%- include('../partials/head') %>
<body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
  <%- include('../partials/nav') %>

  <main class="max-w-7xl mx-auto px-6 py-12">
    <div class="mb-10 rounded-[32px] border border-slate-800 bg-slate-900/90 p-8 shadow-2xl shadow-slate-950/40">
      <h1 class="text-4xl font-semibold text-white text-center">Your Hosted Properties</h1>
      <p class="mx-auto mt-3 max-w-2xl text-center text-slate-400">Manage your listings, update property details, or remove homes from your portfolio.</p>
    </div>

    <% if (registeredHomes.length === 0) { %>
      <div class="flex items-center justify-center min-h-[420px] rounded-[32px] border border-slate-800 bg-slate-900/90 p-10 shadow-2xl shadow-slate-950/40">
        <div class="text-center">
          <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-slate-800 text-sky-300">
            <i class="fa-solid fa-house"></i>
          </div>
          <h2 class="text-3xl font-bold text-white mb-3">No Registered Properties Yet</h2>
          <p class="text-slate-400 mb-8">Register your properties and start hosting guests around the world.</p>
          <a href="/host/add-home" class="inline-flex items-center gap-2 rounded-full bg-sky-500 px-7 py-3 text-sm font-semibold text-slate-950 transition hover:bg-sky-400">
            <i class="fa-solid fa-plus"></i>
            Register Home
          </a>
        </div>
      </div>
    <% } else { %>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <% registeredHomes.forEach((home) => { %>
          <% const ratingValue = parseFloat(home.rating) || 0; %>
          <% const filledStars = Math.round(ratingValue); %>
          <% const emptyStars = 5 - filledStars; %>
          <article class="group overflow-hidden rounded-[32px] border border-slate-800 bg-slate-900/90 shadow-2xl shadow-slate-950/40 transition duration-300 hover:-translate-y-1">
            <% if (home.photo) { %>
              <img src="<%= home.photo %>" alt="<%= home.name %>" class="h-56 w-full object-cover transition duration-300 group-hover:scale-105" />
            <% } else { %>
              <div class="flex h-56 items-center justify-center bg-slate-800 text-slate-500">No image</div>
            <% } %>
            <div class="p-6">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-xl font-semibold text-white mb-2"><%= home.name %></h3>
                  <p class="text-sm text-slate-400"><%= home.location %></p>
                </div>
                <span class="rounded-full bg-slate-800 px-3 py-1 text-sm font-semibold text-sky-300">
                  <i class="fa-solid fa-star text-yellow-400"></i>
                  <%= ratingValue.toFixed(1) %>
                </span>
              </div>
              <div class="mt-4 mb-6 text-slate-400 line-clamp-2"><%= home.description || 'Manage this listing and update your property details anytime.' %></div>
              <div class="flex flex-wrap items-center gap-3">
                <a href="/host/edit-home/<%= home._id %>?editing=true" class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-950/90 px-4 py-2 text-sm font-semibold text-slate-100 transition hover:bg-slate-800">
                  <i class="fa-solid fa-pen"></i> Edit
                </a>
                <form action="/host/host-home-list/remove/<%= home._id %>" method="POST" class="inline-block">
                  <button type="submit" class="inline-flex items-center gap-2 rounded-full bg-red-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-red-600">
                    <i class="fa-solid fa-trash"></i> Delete
                  </button>
                </form>
              </div>
            </div>
          </article>
        <% }); %>
      </div>
    <% } %>
  </main>
</body>
</html>

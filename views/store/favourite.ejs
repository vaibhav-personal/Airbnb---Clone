<%- include('../partials/head') %>
<body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
  <%- include('../partials/nav') %>

  <section class="border-b border-slate-800 bg-slate-900/90 py-14 shadow-inner shadow-slate-950/20">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h1 class="text-5xl font-bold text-white">Your Favourite Homes</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">Save and manage homes you love for future stays.</p>
    </div>
  </section>

  <main class="max-w-7xl mx-auto px-6 py-14">
    <% if (favouriteHomes.length === 0) { %>
      <div class="flex items-center justify-center min-h-[500px]">
        <div class="max-w-md rounded-[32px] border border-slate-800 bg-slate-900/90 p-10 text-center shadow-2xl shadow-slate-950/30">
          <div class="mx-auto mb-6 flex h-24 w-24 items-center justify-center rounded-full bg-slate-800 text-sky-300">
            <i class="fa-solid fa-heart text-4xl"></i>
          </div>
          <h2 class="text-3xl font-bold text-white">No Favourites Yet</h2>
          <p class="mt-4 text-slate-400 leading-relaxed">Save homes you love and access them anytime from your favourites list.</p>
          <a href="/homelist" class="mt-8 inline-flex items-center gap-2 rounded-full bg-sky-500 px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-sky-400">
            <i class="fa-solid fa-house"></i>
            Browse Homes
          </a>
        </div>
      </div>
    <% } else { %>
      <div class="mb-10 flex flex-col gap-4 rounded-[32px] border border-slate-800 bg-slate-900/90 p-5 shadow-2xl shadow-slate-950/30 sm:flex-row sm:justify-between sm:items-center">
        <p class="text-slate-300 text-lg font-semibold"><i class="fa-regular fa-bookmark"></i> <%= favouriteHomes.length %> homes saved</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <% favouriteHomes.forEach((home) => { %>
          <% const ratingValue = parseFloat(home.rating) || 0; %>
          <% const filledStars = Math.round(ratingValue); %>
          <% const emptyStars = 5 - filledStars; %>
          <article class="overflow-hidden rounded-[32px] border border-slate-800 bg-slate-900/90 shadow-2xl shadow-slate-950/30 transition duration-300 hover:-translate-y-1">
            <% if (home.photo) { %>
              <img src="<%= home.photo %>" alt="<%= home.name %>" class="h-56 w-full object-cover transition duration-300" />
            <% } else { %>
              <div class="flex h-56 items-center justify-center bg-slate-800 text-slate-500">No image</div>
            <% } %>
            <div class="p-6">
              <h3 class="text-xl font-semibold text-white mb-2"><%= home.name %></h3>
              <p class="text-sm text-slate-400 mb-4"><%= home.location %></p>
              <div class="mb-4 flex items-center gap-2 text-sm text-slate-400">
                <div class="flex gap-1">
                  <% for (let i = 0; i < filledStars; i++) { %>
                    <span class="text-yellow-300">★</span>
                  <% } %>
                  <% for (let i = 0; i < emptyStars; i++) { %>
                    <span class="text-slate-700">★</span>
                  <% } %>
                </div>
                <span><%= ratingValue.toFixed(1) %></span>
              </div>
              <div class="mb-6 flex items-center justify-between gap-4">
                <div>
                  <span class="text-2xl font-semibold text-white">₹<%= home.price %></span>
                  <span class="ml-2 text-sm text-slate-500">per night</span>
                </div>
              </div>
              <div class="grid gap-3 sm:grid-cols-2">
                <a href="/home-list/<%= home._id %>" class="inline-flex items-center justify-center rounded-full bg-sky-500 px-4 py-3 text-sm font-semibold text-slate-950 transition hover:bg-sky-400">Details</a>
                <form action="/favourites/remove/<%= home._id %>" method="POST" class="inline-flex w-full">
                  <button type="submit" class="w-full rounded-full bg-red-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-red-600">Remove</button>
                </form>
              </div>
            </div>
          </article>
        <% }); %>
      </div>
    <% } %>
  </main>
</body>
</html>

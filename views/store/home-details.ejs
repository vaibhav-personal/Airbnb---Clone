<%- include('../partials/head') %>
<body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
  <%- include('../partials/nav') %>

  <main class="flex min-h-[90vh] items-center justify-center px-6 py-12">
    <div class="w-full max-w-5xl rounded-[32px] border border-slate-800 bg-slate-900/90 p-8 shadow-2xl shadow-slate-950/40">
      <% if (home.photo) { %>
        <img src="<%= home.photo %>" alt="<%= home.name %>" class="w-full rounded-[24px] object-cover shadow-xl" />
      <% } else { %>
        <div class="flex h-96 items-center justify-center rounded-[24px] bg-slate-800 text-slate-500">No image</div>
      <% } %>
      <div class="mt-8 grid gap-8 lg:grid-cols-[2fr_1fr] lg:items-start">
        <div>
          <h1 class="text-4xl font-bold text-white"><%= home.name %></h1>
          <p class="mt-3 text-lg text-slate-400"><%= home.location %></p>
          <p class="mt-6 text-base leading-8 text-slate-300"><%= home.description %></p>
          <div class="mt-8 flex flex-wrap items-center gap-4 text-slate-300">
            <div class="flex items-center gap-2 rounded-full border border-slate-800 bg-slate-950/80 px-4 py-2">
              <i class="fa-solid fa-star text-yellow-400"></i>
              <span><%= parseFloat(home.rating || 0).toFixed(1) %> / 5</span>
            </div>
            <div class="flex items-center gap-2 rounded-full border border-slate-800 bg-slate-950/80 px-4 py-2">
              <i class="fa-solid fa-money-bill-wave text-sky-400"></i>
              <span>₹<%= home.price %> per night</span>
            </div>
          </div>
        </div>
        <div class="space-y-4 rounded-[32px] border border-slate-800 bg-slate-950/80 p-6">
          <%- include('../partials/favourite-button', { home: home }) %>
          <a href="/reserve/<%= home._id %>" class="block w-full rounded-2xl bg-sky-500 px-6 py-4 text-center text-lg font-semibold text-slate-950 transition hover:bg-sky-400">Reserve Stay</a>
        </div>
      </div>
    </div>
  </main>
</body>
</html>

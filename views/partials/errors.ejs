<!-- Error Message div -->
<% if (errorMessages && errorMessages.length > 0) { %>
<div class="relative mb-6 rounded-2xl border border-red-500 bg-red-100 px-5 py-4 shadow-sm" role="alert">

  <div class="mb-3 flex items-center gap-3">
    <div class="flex h-9 w-9 items-center justify-center rounded-full bg-red-200 text-red-700">
      <i class="fa-solid fa-circle-exclamation"></i>
    </div>
    <h3 class="text-lg font-bold text-red-700">
      Validation Errors
    </h3>
  </div>

  <ul class="space-y-2 pl-1">
    <% errorMessages.forEach((error) => { %>
    <li class="flex items-start gap-3 text-sm font-medium text-red-700">
      <span class="mt-2 h-2 w-2 rounded-full bg-red-700"><i class="fa-solid fa-xmark text-red-500"></i></span>
      <span class="text-red-500"><%= error %></span>
    </li>
    <% }) %>
  </ul>
</div>
<% } %>
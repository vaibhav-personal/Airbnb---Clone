<form action="/favourites" method="POST">
  <input type="hidden" name="homeId" value="<%= home._id %>" />
  <button type="submit" class="flex-1 rounded-full bg-slate-800 px-6 py-3 text-sm font-semibold text-slate-100 transition hover:bg-slate-700">
    <i class="fa-solid fa-heart-circle-plus mr-2"></i>
    Add to favourites
  </button>
</form>
